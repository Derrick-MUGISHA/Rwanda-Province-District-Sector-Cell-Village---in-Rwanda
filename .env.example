# Runtime
PORT=3000
ENABLE_FULL_DATASET_ENDPOINT=false
RATE_LIMIT_MAX_REQUESTS=120
RATE_LIMIT_WINDOW_MS=60000

# Comma-separated list for browser clients. Leave empty to allow all origins.
ALLOWED_ORIGINS=http://localhost:3000, http://localhost:5173

# Publishing tokens (CI/CD secrets; do not commit real values)
NPM_TOKEN=
PYPI_API_TOKEN=
MAVEN_USERNAME=
MAVEN_PASSWORD=
